@model LoginViewModel

@{
    Layout = null;
}



<div class="card">

    <div class="logo">
        <div class="logo-icon">E</div>
        <span class="logo-name">Edu<span>Nest</span></span>
    </div>

    <div class="card-title">Welcome back</div>
    <div class="card-sub">Sign in to your student portal</div>

    <div class="error-msg" id="errorMsg">Invalid ID or password. Please try again.</div>
    <form asp-action="Login" method="post">

    <div class="form-group">
        <label for="userId">Student ID</label>
        
        <input asp-for="UserName" placeholder="e.g. 21CSE0451" autocomplete="username" />
            <span asp-validation-for="UserName" style="color:red"></span>
    </div>

    <div class="form-group">
        <label for="password">Password</label>
        <input asp-for="Password" type="password" placeholder="Enter your password" autocomplete="current-password" />
            <span asp-validation-for="Password" style="color:red"></span>
    </div>

    <div class="options">
        @* <label class="remember">
            <input type="checkbox" /> Remember me
        </label>
        <a href="#" class="forgot">Forgot password?</a> *@
    </div>

    @* <button  onclick="handleLogin()">Sign In</button> *@
    <button class="btn" type="submit">Login</button>
    </form>
    <div class="card-footer">
        Need help? <a href="#">Contact IT Support</a> · <a href="#">Privacy Policy</a>
    </div>

</div>

    
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #ffffff;
            border-radius: 16px;
            padding: 40px 36px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        }

        /* Logo */
        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: #2d5be3;
            border-radius: 10px;
            display: grid;
            place-items: center;
            font-size: 18px;
            font-weight: 700;
            color: #fff;
        }

        .logo-name {
            font-size: 20px;
            font-weight: 600;
            color: #0f1117;
        }

            .logo-name span {
                color: #e8a117;
            }

        /* Header */
        .card-title {
            text-align: center;
            font-size: 20px;
            font-weight: 600;
            color: #0f1117;
            margin-bottom: 6px;
        }

        .card-sub {
            text-align: center;
            font-size: 13.5px;
            color: #6b7280;
            margin-bottom: 28px;
        }

        /* Form */
        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            height: 44px;
            padding: 0 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #0f1117;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

            input::placeholder {
                color: #9ca3af;
            }

            input:focus {
                border-color: #2d5be3;
                box-shadow: 0 0 0 3px rgba(45,91,227,0.1);
            }

        /* Options row */
        .options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .remember {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            color: #6b7280;
            cursor: pointer;
        }

            .remember input[type="checkbox"] {
                width: auto;
                height: auto;
                accent-color: #2d5be3;
            }

        .forgot {
            font-size: 13px;
            color: #2d5be3;
            font-weight: 500;
            text-decoration: none;
        }

            .forgot:hover {
                text-decoration: underline;
            }

        /* Submit */
        .btn {
            width: 100%;
            height: 46px;
            background: #2d5be3;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14.5px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background 0.15s;
            margin-bottom: 20px;
        }

            .btn:hover {
                background: #2450cc;
            }

            .btn:active {
                background: #1d44b8;
            }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb;
            }

            .divider span {
                font-size: 12px;
                color: #9ca3af;
            }

        /* SSO */
        .btn-sso {
            width: 100%;
            height: 44px;
            background: #fff;
            color: #374151;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-sso:hover {
                background: #f9fafb;
            }

        /* Footer */
        .card-footer {
            text-align: center;
            font-size: 12.5px;
            color: #9ca3af;
            margin-top: 24px;
        }

            .card-footer a {
                color: #6b7280;
                text-decoration: none;
            }

                .card-footer a:hover {
                    text-decoration: underline;
                }

        /* Error */
        .error-msg {
            display: none;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 7px;
            padding: 9px 12px;
            font-size: 13px;
            color: #dc2626;
            margin-bottom: 16px;
        }

            .error-msg.show {
                display: block;
            }
    </style>
