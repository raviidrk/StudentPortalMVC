@using StudentPortal.DTO
@model IEnumerable<StaffResponseDto>

<div class="container mt-4">

    <h3 class="mb-3">Staff List</h3>

    <a asp-action="AddStaff" asp-route-id="0" class="btn btn-primary mb-3">
        Create New
    </a>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Full Name</th>
                <th>Phone Number</th>
                <th>User Name</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.FullName</td>
                        
                        <td>@user.PhoneNumber</td>
                        <td>@user.UserName</td>
                        <td>@user.Role</td>
                        <td>
                            <a asp-action="EditStaff" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No records found</td>
                </tr>
            }
        </tbody>
    </table>

</div>